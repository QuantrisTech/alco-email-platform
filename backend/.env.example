# Database — MUST include a database name in the path (e.g. /alco_email)
# even though Mongo will create it on first write if it doesn't exist yet.
# scheduler.py relies on client.get_default_database() to name the
# apscheduler_jobs collection correctly — an URI with no path segment
# breaks that at startup.
# Use a SEPARATE database within your existing Atlas cluster from the CRM's
# database — same cluster/billing, isolated collections, so a bad query
# against email_logs can't touch CRM contact documents.
MONGO_URI=mongodb+srv://user:password@your-cluster.mongodb.net/alco_email

# SMTP (Gmail — see README for daily-limit caveats)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=support@alco.com
SMTP_PASSWORD=your_app_password
SMTP_DAILY_LIMIT=450          # stay under Gmail's ~500/day cap with headroom

# CRM
CRM_API_URL=https://your-crm.vercel.app/api
CRM_WEBHOOK_SECRET=change_me   # required on inbound webhook calls, see automations router

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Unsubscribe link signing (separate from JWT_SECRET — rotate independently)
UNSUB_SECRET=change_me_to_a_different_long_random_string

PLATFORM_URL=https://platform.alco.com
